# Server-only Neon connection string.
# Use the Neon development branch locally and in preview deployments.
# Never commit a real connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Authentication
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Jakarta

# Optional AI provider configuration for Phase 5
AI_PROVIDER=
AI_API_KEY=
